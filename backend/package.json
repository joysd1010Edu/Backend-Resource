{
  "name": "backend",
  "version": "1.0.0",
  "description": "Online test platform backend with Express and Mongoose",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "src/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "build": "echo \"No build step required\"",
    "start": "node src/server.js",
    "seed:users": "node src/scripts/seedUsers.js",
    "test": "jest --runInBand",
    "test:api": "newman run postman/IBOS-Backend.postman_collection.json"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.1",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "newman": "^6.2.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.js"
    ]
  }
}
